---
// Line-drawn product art for the range. Decorative — the card copy
// carries the meaning, so every SVG is aria-hidden.
const { kind } = Astro.props;
---
{kind === 'everyday' && (
  <svg viewBox="0 0 200 120" aria-hidden="true" focusable="false">
    <g fill="none" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round">
      <path d="M62 16 q40 -5 76 2 q3 44 0 86 q-38 6 -76 -2 q-3 -43 0 -86 Z" />
      <path d="M62 16 q-4 2 -4 6 q-3 40 0 80 q0 4 4 4" stroke-width="1.4" opacity=".6" />
    </g>
    <g fill="currentColor" opacity=".55">
      {[0, 1, 2, 3, 4].map((r) => [0, 1, 2, 3].map((c) => (
        <circle cx={82 + c * 13} cy={36 + r * 13} r="1.3" />
      )))}
    </g>
    <path d="M118 14 q2 45 0 92" stroke="var(--hl)" stroke-width="4" fill="none" opacity=".9" />
    <path d="M138 100 q3 -2 2 -6" stroke="currentColor" stroke-width="1.2" fill="none" opacity=".5" />
  </svg>
)}
{kind === 'pocket' && (
  <svg viewBox="0 0 200 120" aria-hidden="true" focusable="false">
    <g fill="none" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round" stroke-linecap="round">
      <path d="M74 26 q26 -4 52 1 q3 32 0 66 q-26 5 -52 -1 q-3 -33 0 -66 Z" />
      <path d="M80 34 q0 27 0 52 M86 33 q0 27 0 52" stroke-width="1" opacity=".4" />
      <path d="M96 46 q14 -2 22 0 M96 56 q12 -2 20 0 M96 66 q14 -2 18 0" stroke-width="1.3" opacity=".55" />
    </g>
    <path d="M70 92 q-8 8 -16 6" stroke="currentColor" stroke-width="1.3" fill="none" opacity=".45" stroke-linecap="round" />
    <path d="M126 24 l8 -8 M130 30 l10 -6" stroke="var(--accent)" stroke-width="1.6" fill="none" stroke-linecap="round" opacity=".8" />
  </svg>
)}
{kind === 'ledger' && (
  <svg viewBox="0 0 200 120" aria-hidden="true" focusable="false">
    <g fill="none" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round">
      <path d="M56 14 h84 q4 0 4 4 v82 q0 4 -4 4 h-84 Z" />
      <path d="M56 14 h14 v90 h-14 q-4 0 -4 -4 v-82 q0 -4 4 -4 Z" fill="currentColor" fill-opacity=".14" />
    </g>
    <g stroke="currentColor" stroke-width="1" opacity=".45">
      <path d="M84 38 h50 M84 50 h50 M84 62 h50 M84 74 h50 M84 86 h50" />
    </g>
    <path d="M92 26 v70" stroke="var(--margin)" stroke-width="1.4" opacity=".8" />
    <path d="M100 44 q10 -6 18 0" stroke="var(--blue)" stroke-width="1.6" fill="none" stroke-linecap="round" opacity=".8" />
  </svg>
)}
{kind === 'drafting' && (
  <svg viewBox="0 0 200 120" aria-hidden="true" focusable="false">
    <g fill="none" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round">
      <path d="M54 24 h92 v76 q-46 6 -92 0 Z" />
      <path d="M54 24 v-6 h92 v6" stroke-dasharray="3 4" stroke-width="1.3" opacity=".6" />
    </g>
    <g stroke="currentColor" stroke-width=".8" opacity=".35">
      <path d="M66 24 v78 M80 24 v79 M94 24 v80 M108 24 v80 M122 24 v79 M136 24 v78" />
      <path d="M54 38 h92 M54 52 h92 M54 66 h92 M54 80 h92 M54 94 h91" />
    </g>
    <path d="M70 84 L98 48 L126 84" stroke="var(--blue)" stroke-width="1.7" fill="none" stroke-linejoin="round" opacity=".85" />
    <path d="M84 66 h28" stroke="var(--blue)" stroke-width="1.2" opacity=".6" />
  </svg>
)}
{kind === 'pen' && (
  <svg viewBox="0 0 200 120" aria-hidden="true" focusable="false">
    <g fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
      <path d="M42 92 L118 38 q8 -6 16 -2 l8 6 q6 6 -1 12 L72 104 q-16 6 -30 -12 Z" transform="translate(8 -8)" />
      <path d="M50 84 l16 20" stroke-width="1.2" opacity=".5" />
      <path d="M50 84 q-10 6 -14 18 q12 0 22 -6" stroke-width="1.6" />
      <path d="M43 95 q2 3 5 4" stroke-width="1.2" />
    </g>
    <path d="M126 44 l10 8" stroke="var(--accent)" stroke-width="3.4" stroke-linecap="round" opacity=".9" />
    <path d="M36 106 q28 4 52 -8" stroke="var(--blue)" stroke-width="1.6" fill="none" stroke-linecap="round" opacity=".7" />
  </svg>
)}
{kind === 'ink' && (
  <svg viewBox="0 0 200 120" aria-hidden="true" focusable="false">
    <g fill="none" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round">
      <path d="M84 20 h32 v12 q14 8 14 24 v34 q0 12 -12 12 h-36 q-12 0 -12 -12 v-34 q0 -16 14 -24 Z" />
      <path d="M84 32 h32" stroke-width="1.3" opacity=".6" />
    </g>
    <path d="M72 66 v24 q0 10 10 10 h36 q10 0 10 -10 v-24 q-28 8 -56 0 Z" fill="var(--blue)" opacity=".5" />
    <rect x="86" y="48" width="28" height="26" rx="3" fill="none" stroke="currentColor" stroke-width="1.3" opacity=".7" />
    <text x="100" y="65" text-anchor="middle" font-family="Space Mono, monospace" font-size="9" fill="currentColor" opacity=".8">No.9</text>
    <path d="M140 96 q8 -2 10 -8" stroke="var(--blue)" stroke-width="1.4" fill="none" stroke-linecap="round" opacity=".6" />
  </svg>
)}
